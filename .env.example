# Puerto del backend
PORT=3000

# Neon Postgres (connection string completa, con ?sslmode=require)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/DBNAME?sslmode=require

# Evolution API
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=tu_api_key_de_evolution
# Prefijo de instancia; cada usuario usa {prefijo}-{numero}
EVOLUTION_INSTANCE_PREFIX=whatsapp-scheduler

# Auth: secreto para firmar JWT (usa un valor largo y aleatorio)
JWT_SECRET=cambia_esto_por_un_valor_aleatorio_largo
JWT_EXPIRES_IN=30d

# Cron del scheduler (por defecto cada minuto)
CRON_EXPRESSION=* * * * *
