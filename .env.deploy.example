# Variables del despliegue (docker-compose). Copia a .env y completa.
# NUNCA subas el .env real al repositorio (.gitignore ya lo excluye).
#
# El reverse proxy + HTTPS lo maneja APACHE en el host, no Docker.
# El subdominio del backend (ej. api.tudominio.com) se configura en el
# VirtualHost de Apache (ver apache-backend.conf.example y DEPLOY.md), no aquí.

# --- Neon Postgres (datos del backend: users + schedules) ---
# Connection string completa, con ?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/DBNAME?sslmode=require

# --- Evolution API ---
# La misma clave la usa el backend para hablar con Evolution y Evolution para autenticar.
# Genera una: openssl rand -hex 32
EVOLUTION_API_KEY=pon_aqui_una_clave_larga_y_aleatoria
EVOLUTION_INSTANCE_PREFIX=whatsapp-scheduler

# Password del Postgres dedicado a Evolution (interno al compose).
# Genera una: openssl rand -hex 24
EVOLUTION_DB_PASSWORD=pon_aqui_otra_clave_larga_y_aleatoria

# --- Auth del backend ---
# Genera uno: openssl rand -hex 48
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=30d

# --- Scheduler ---
CRON_EXPRESSION=* * * * *
